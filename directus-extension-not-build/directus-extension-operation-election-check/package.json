{
  "name": "directus-extension-klimawahl-operations",
  "description": "Bundle: generate-questions + send-candidate-mails operations, plus an Elections action interface.",
  "version": "2.0.0",
  "keywords": ["directus", "directus-extension", "directus-custom-bundle"],
  "type": "module",
  "files": ["dist"],
  "directus:extension": {
    "type": "bundle",
    "host": "^10.13.0",
    "path": {
      "app": "dist/app.js",
      "api": "dist/api.js"
    },
    "entries": [
      {
        "type": "operation",
        "name": "operation-generate-questions",
        "source": {
          "app": "src/generate-questions/app.js",
          "api": "src/generate-questions/api.js"
        }
      },
      {
        "type": "operation",
        "name": "operation-send-candidate-mails",
        "source": {
          "app": "src/send-candidate-mails/app.js",
          "api": "src/send-candidate-mails/api.js"
        }
      },
      {
        "type": "interface",
        "name": "interface-election-actions",
        "source": "src/interface/index.js"
      }
    ]
  },
  "scripts": {
    "build": "directus-extension build",
    "dev":   "directus-extension build -w --no-minify",
    "link":  "directus-extension link"
  },
  "devDependencies": {
    "@directus/extensions-sdk": "11.0.9",
    "vue": "^3.4.21"
  }
}
