{
  "name": "slugify",
  "description": "Please enter a description for your extension",
  "icon": "extension",
  "version": "1.0.0",
  "keywords": [
    "directus",
    "directus-extension",
    "directus-custom-operation"
  ],
  "type": "module",
  "directus:extension": {
    "type": "operation",
    "path": {
      "app": "dist/app.js",
      "api": "dist/api.js"
    },
    "source": {
      "app": "src/app.ts",
      "api": "src/api.ts"
    },
    "host": "^11.0.0"
  },
  "scripts": {
    "build": "directus-extension build",
    "dev": "directus-extension build -w --no-minify",
    "link": "directus-extension link"
  },
  "devDependencies": {
    "@directus/extensions-sdk": "17.1.4",
    "esbuild": "^0.28.0",
    "typescript": "^5.0.0",
    "vue": "^3.3.4"
  },
  "dependencies": {
    "slugify": "^1.6.6"
  },
  "overrides": {
    "esbuild": "^0.28.0"
  }
}
