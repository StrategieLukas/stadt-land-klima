{
  "name": "election-check",
  "description": "Bundle: generate-questions + send-candidate-mails operations, plus an Elections action interface.",
  "version": "2.0.0",
  "keywords": ["directus", "directus-extension", "directus-custom-bundle"],
  "type": "module",
  "files": ["dist"],
  "directus:extension": {
    "type": "bundle",
    "host": "^11.0.0",
    "path": {
      "app": "dist/app.js",
      "api": "dist/api.js"
    },
    "entries": [
      {
        "type": "operation",
        "name": "operation-generate-questions",
        "source": {
          "app": "src/generate-questions/app.ts",
          "api": "src/generate-questions/api.ts"
        }
      },
      {
        "type": "operation",
        "name": "operation-send-candidate-mails",
        "source": {
          "app": "src/send-candidate-mails/app.ts",
          "api": "src/send-candidate-mails/api.ts"
        }
      },
      {
        "type": "interface",
        "name": "interface-election-actions",
        "source": "src/interface/index.ts"
      },
      {
        "type": "endpoint",
        "name": "election-actions",
        "source": "src/endpoint/index.ts"
      }
    ]
  },
  "scripts": {
    "build": "directus-extension build",
    "dev":   "directus-extension build -w --no-minify",
    "link":  "directus-extension link"
  },
  "devDependencies": {
    "@directus/extensions-sdk": "17.1.4",
    "esbuild": "^0.28.0",
    "typescript": "^5.0.0",
    "vue": "^3.4.21"
  },
  "overrides": {
    "esbuild": "^0.28.0"
  }
}
