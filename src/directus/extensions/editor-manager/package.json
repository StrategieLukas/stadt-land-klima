{
	"name": "editor-manager",
	"description": "Bundle: add-editor + delete-editor operations for managing LokalteamMitglied editors",
	"version": "1.0.0",
	"keywords": [
		"directus",
		"directus-extension",
		"directus-extension-bundle",
		"directus-extension-operation"
	],
	"type": "module",
	"files": [
		"dist"
	],
	"directus:extension": {
		"type": "bundle",
		"host": "^11.0.0",
		"path": {
			"app": "dist/app.js",
			"api": "dist/api.js"
		},
		"entries": [
			{
				"type": "operation",
				"name": "operation-add-editor",
				"source": {
					"app": "src/add-editor/app.ts",
					"api": "src/add-editor/api.ts"
				}
			},
			{
				"type": "operation",
				"name": "delete-editor",
				"source": {
					"app": "src/delete-editor/app.ts",
					"api": "src/delete-editor/api.ts"
				}
			}
		]
	},
	"scripts": {
		"build": "directus-extension build",
		"dev": "directus-extension build -w --no-minify",
		"link": "directus-extension link"
	},
	"devDependencies": {
		"@directus/extensions-sdk": "17.1.4",
		"@directus/types": "^11.0.0",
		"@types/lodash-es": "^4.17.12",
		"esbuild": "^0.28.0",
		"typescript": "^5.0.0",
		"vue": "^3.4.21"
	},
	"overrides": {
		"esbuild": "^0.28.0"
	},
	"dependencies": {
		"@directus/errors": "^2.3.1"
	}
}
