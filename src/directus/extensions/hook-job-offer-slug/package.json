{
  "name": "hook-content-slugs",
  "description": "Generates content slugs for Directus collections.",
  "icon": "link",
  "version": "1.0.0",
  "keywords": [
    "directus",
    "directus-extension",
    "directus-extension-hook"
  ],
  "type": "module",
  "files": [
    "dist"
  ],
  "directus:extension": {
    "type": "hook",
    "path": "dist/index.js",
    "source": "src/index.ts",
    "host": "^11.0.0"
  },
  "scripts": {
    "build": "directus-extension build",
    "dev": "directus-extension build -w --no-minify",
    "link": "directus-extension link",
    "validate": "directus-extension validate"
  },
  "dependencies": {
    "slugify": "^1.6.6"
  },
  "devDependencies": {
    "@directus/extensions-sdk": "17.1.4",
    "@directus/types": "^11.0.0",
    "esbuild": "^0.28.0",
    "typescript": "^5.0.0"
  },
  "overrides": {
    "esbuild": "^0.28.0"
  }
}
