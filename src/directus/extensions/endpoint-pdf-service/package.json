{
	"name": "pdf-service",
  	"description": "Generate a PDF for a municipality",
	"icon": "extension",
	"version": "1.0.0",
	"keywords": [
		"directus",
		"directus-extension",
		"directus-extension-endpoint"
	],
	"type": "module",
	"files": [
		"dist"
	],
	"directus:extension": {
		"type": "endpoint",
		"path": "dist/index.js",
		"source": "src/index.ts",
		"host": "^11.0.0"
	},
	"scripts": {
		"build": "directus-extension build",
		"dev": "directus-extension build -w --no-minify",
		"link": "directus-extension link",
		"validate": "directus-extension validate"
	},
	"devDependencies": {
		"@directus/extensions-sdk": "17.1.4",
		"@directus/types": "^11.0.0",
		"@types/express": "^4.17.21",
		"@types/node": "^20.0.0",
		"esbuild": "^0.28.0",
		"html-to-text": "9.0.5",
		"typescript": "^5.0.0"
	},
	"overrides": {
		"esbuild": "^0.28.0"
	}
}
