{
  "name": "frontend",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint:js": "eslint --ext \".js,.vue\" --ignore-path .gitignore ../../directus-extension-not-build/**",
    "lint:prettier": "prettier --check .",
    "lint": "npm run lint:js && npm run lint:prettier",
    "lintfix": "prettier --write --list-different . && npm run lint:js --fix",
    "lintExtensions:js": "eslint --ext \".js\" --ignore-path .gitignore ../../directus-extension-not-build/**",
    "lintExtensions:prettier": "prettier --check ../../directus-extension-not-build/**",
    "lintExtensions": "npm run lintExtensions:js && npm run lintExtensions:prettier",
    "lintfixExtensions": "prettier --write --list-different ../../directus-extension-not-build/** && npm run lintExtensions:js --fix"
  },
  "devDependencies": {
    "@nuxt/devtools": "latest",
    "@nuxt/eslint-config": "^0.2.0",
    "baseline-browser-mapping": "^2.10.13",
    "eslint": "^8.49.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "eslint-plugin-vue": "^9.17.0",
    "nuxt": "^3.7.0",
    "prettier": "^3.0.3",
    "prettier-plugin-tailwindcss": "^0.5.4"
  },
  "dependencies": {
    "@apollo/client": "^4.0.7",
    "@blokkli/editor": "^1.3.4",
    "@directus/sdk": "^11.0.3",
    "@iconify/json": "^2.2.453",
    "@iconify/vue": "^5.0.0",
    "@nuxtjs/leaflet": "^1.3.2",
    "@tailwindcss/typography": "^0.5.10",
    "altcha": "^3.0.1",
    "autoprefixer": "^10.4.15",
    "chart.js": "^4.4.0",
    "chartjs-chart-treemap": "^3.1.0",
    "daisyui": "^3.7.3",
    "graphql": "^16.11.0",
    "graphql-tag": "^2.12.6",
    "leaflet": "^1.9.4",
    "linkify-string": "^4.1.3",
    "linkifyjs": "^4.1.3",
    "lodash": "^4.17.21",
    "markdown-it": "^14.1.0",
    "meilisearch": "^0.38.0",
    "ml-pca": "^4.1.1",
    "postcss": "^8.4.29",
    "sanitize-html": "^2.11.0",
    "tailwindcss": "^3.3.3",
    "vega": "^6.2.0",
