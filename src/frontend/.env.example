APP_ENV=development
SERVER_DIRECTUS_URL=http://directus:8055
CLIENT_DIRECTUS_URL=http://localhost:8081
PUBLIC_URL=http://localhost:8080
FALLBACK_LOCALE=de-DE
HOST=0.0.0.0
DIRECTUS_TOKEN=frontend-dev-token
PLAUSIBLE_ANALYTICS_URL=url_to_plausible_analytics_instance
PLAUSIBLE_ANALYTICS_DOMAIN=domain_as_registered_in_plausible_analytics
NODE_OPTIONS=--max-old-space-size=2048
npm_config_jobs=2
STADTLANDZAHL_URL=http://localhost:8000/graphql/

# Public-facing URL of this Nuxt app (used in admin notification emails)
APP_PUBLIC_URL=http://localhost:8080

# Public-facing URL of the Directus admin panel (used in admin notification emails)
DIRECTUS_PUBLIC_URL=http://localhost:8081

# Registration: admin notification email recipient
ADMIN_NOTIFICATION_EMAIL=info@stadt-land-klima.de

# Registration: welcome email link targets
WELCOME_EMAIL_TUTORIAL_URL=
WELCOME_EMAIL_CALENDAR_URL=
WELCOME_EMAIL_SIGNAL_URL=

ALTCHA_SECRET=dev-secret-change-in-production
DIRECTUS_ADMIN_TOKEN=

# Directus flow webhook URLs for sending emails (set after importing flows)
DIRECTUS_FLOW_NOTIFY_ADMIN=http://directus:8055/flows/trigger/<flow-id>
DIRECTUS_FLOW_WELCOME_EMAIL=http://directus:8055/flows/trigger/<flow-id>